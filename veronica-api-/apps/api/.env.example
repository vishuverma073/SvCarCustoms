DATABASE_URL=postgresql://postgres:postgres@localhost:5432/veronica
PORT=8787
LOG_LEVEL=info
NODE_ENV=development
# Admin session signing secret. Generate via: openssl rand -hex 32
JWT_ADMIN_SECRET=replace-with-openssl-rand-hex-32-output

# Image uploads (Task 1.8). Supabase project URL + service_role key (NOT anon).
# Dashboard → Settings → API. Requires a public-read bucket named "product-images".
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
